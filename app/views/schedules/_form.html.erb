<%= form_with(model: schedule) do |form| %>
  <% if schedule.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(schedule.errors.count, "error") %> prohibited this schedule from being saved:</h2>

      <ul>
        <% schedule.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  
  <div class = "container p-4 border shadow-sm row">
    <div class="field col-12">
      <%= form.label :title, class: "mb-2" %>
      <%= form.text_field :title, class: "w-100" %>
    </div>

    <div class="field col-md-6">
      <%= form.label :start_date, class: "mb-2" %>
      <%= form.date_select :start_date %>
    </div>

    <div class="field col-md-6">
      <%= form.label :end_date, class: "mb-2" %>
      <%= form.date_select :end_date %>
    </div>

    <div class="field col-12 d-flex align-items-center">
      <%= form.check_box :all_day %>
      <span class = "ms-2">終日の場合はチェックを入れます</span>
    </div>

    <div class="field col-12">
      <%= form.label :memo, "スケジュールメモ", class: "mb-2" %>
      <%= form.text_area :memo, class: "w-100 p-2 memo-container" %>
    </div>

    <div class = "btn-container d-flex justify-content-end">
      <div>
        <%= link_to 'キャンセル', schedules_path, class: 'btn border' %>
      </div>

      <div class="actions">
        <%= form.submit "保存", class: "btn btn-primary" %>
      </div>
    </div>
  </div> 
<% end %>
